{
  "name": "cursor-responses-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Authenticated Open Responses gateway backed by the official Cursor SDK.",
  "type": "module",
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch server/index.ts",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "accept": "tsx scripts/accept.ts"
  },
  "dependencies": {
    "@cursor/sdk": "^1.0.24",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^5.2.1",
    "yaml": "^2.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^24.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
